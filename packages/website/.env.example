# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Production URLs (override in .env.local)
# NEXT_PUBLIC_API_URL=https://api.cargolink.com/api
# NEXT_PUBLIC_WS_URL=https://api.cargolink.com

# Application Settings
NEXT_PUBLIC_APP_NAME=CargoLink
NEXT_PUBLIC_APP_VERSION=1.0.0

# Features Flags
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_REAL_TIME_TRACKING=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Security
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Payment
NEXT_PUBLIC_IYZICO_SANDBOX=true
NEXT_PUBLIC_PAYTR_SANDBOX=true

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/*,application/pdf

# Monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true