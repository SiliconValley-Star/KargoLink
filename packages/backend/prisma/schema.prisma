// ============================================================================
// FILE STORAGE
// ============================================================================

model File {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // File Information
  key             String    @unique
  originalName    String
  fileName        String
  mimeType        String
  size            BigInt
  hash            String    @unique

  // File Classification
  type            String    @default("OTHER")
  category        String?
  tags            String    // JSON array as string

  // Storage Information
  provider        String    @default("AWS_S3")
  bucketName      String
  path            String
  url             String

  // Access Control
  isPublic        Boolean   @default(false)
  accessLevel     String    @default("private")

  // Processing
  status          String    @default("ACTIVE")
  processingStatus String?  // JSON as string

  // Thumbnails & Variants
  thumbnailKey    String?
  thumbnailUrl    String?
  variants        String    @default("{}")  // JSON as string

  // Metadata
  metadata        String    @default("{}")  // JSON as string
  exifData        String?   // JSON as string
  dimensions      String?   // JSON as string
  duration        Int?

  // Upload Information
  uploadedById    String?
  uploadedBy      User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadSource    String    @default("web")
  uploadedAt      DateTime  @default(now())

  // Usage Tracking
  downloadCount   Int       @default(0)
  lastAccessedAt  DateTime?

  // Expiration & Cleanup
  expiresAt       DateTime?
  autoCleanup     Boolean   @default(false)

  // Virus Scanning
  virusScanStatus String?   @default("pending")
  virusScanResult String?   // JSON as string
  virusScanAt     DateTime?

  // Relations
  associations    FileAssociation[]
  shares          FileShare[]
  versions        FileVersion[]
  accessLogs      FileAccessLog[]

  @@map("files")
}

model FileAssociation {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())

  // File
  fileId        String
  file          File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // Associated Entity
  entityType    String
  entityId      String
  fieldName     String?

  // Association Metadata
  purpose       String?
  displayOrder  Int?      @default(0)
  metadata      String    @default("{}")  // JSON as string

  @@map("file_associations")
}

model FileShare {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // File
  fileId            String
  file              File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // Share Information
  token             String    @unique
  sharedById        String
  sharedBy          User      @relation("FileSharesGiven", fields: [sharedById], references: [id])
  sharedWithEmail   String?
  sharedWithUserId  String?
  sharedWithUser    User?     @relation("FileSharesReceived", fields: [sharedWithUserId], references: [id], onDelete: SetNull)

  // Access Control
  permissions       String    @default("[\"read\"]")  // JSON array as string
  expiresAt         DateTime?
  maxDownloads      Int?
  downloadCount     Int       @default(0)

  // Password Protection
  password          String?
  requiresPassword  Boolean   @default(false)

  // Status
  isActive          Boolean   @default(true)
  lastAccessedAt    DateTime?

  // Metadata
  note              String?
  metadata          String    @default("{}")  // JSON as string

  @@map("file_shares")
}

model FileVersion {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())

  // Original File
  originalFileId  String
  originalFile    File      @relation(fields: [originalFileId], references: [id], onDelete: Cascade)

  // Version Information
  versionNumber   Int       @default(1)
  changelog       String?

  // File Information
  key             String
  originalName    String
  fileName        String
  mimeType        String
  size            BigInt
  hash            String
  url             String

  // Processing
  status          String    @default("ACTIVE")

  // Upload Information
  uploadedById    String?
  uploadedBy      User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt      DateTime  @default(now())

  // Metadata
  metadata        String    @default("{}")  // JSON as string

  @@map("file_versions")
}

model FileAccessLog {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())

  // File
  fileId          String
  file            File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // User
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId       String?

  // Access Information
  action          String
  ipAddress       String?
  userAgent       String?
  referer         String?

  // Response Information
  responseStatus  Int?
  bytesServed     BigInt?
  duration        Int?

  // Metadata
  metadata        String    @default("{}")  // JSON as string

  @@map("file_access_logs")
}

// FileStatus: UPLOADING, ACTIVE, PROCESSING, FAILED, DELETED
// FileType: AVATAR, DOCUMENT, IMAGE, VIDEO, AUDIO, ARCHIVE, OTHER
// StorageProvider: AWS_S3, GOOGLE_CLOUD, AZURE_BLOB, LOCAL