{
  "name": "@cargolink/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "CargoLink Mobile App - React Native with TypeScript",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "vite --host",
    "web:dev": "vite dev --host --port 3003",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "expo:start": "expo start",
    "expo:android": "expo run:android",
    "expo:ios": "expo run:ios",
    "expo:web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace CargoLinkMobile.xcworkspace -scheme CargoLinkMobile archive",
    "clean": "react-native clean",
    "clean:android": "cd android && ./gradlew clean",
    "clean:ios": "cd ios && xcodebuild clean",
    "pod-install": "cd ios && pod install"
  },
  "keywords": [
    "cargolink",
    "mobile",
    "react-native",
    "typescript",
    "logistics"
  ],
  "author": "CargoLink Team",
  "license": "MIT",
  "dependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/webpack-config": "^19.0.1",
    "@hookform/resolvers": "^3.3.2",
    "@react-native-async-storage/async-storage": "^1.19.5",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/core": "^6.4.17",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^7.5.1",
    "@react-navigation/stack": "^6.3.20",
    "@tanstack/react-query": "^5.8.4",
    "axios": "^1.6.0",
    "expo": "^49.0.23",
    "expo-camera": "~16.0.18",
    "expo-location": "~18.0.10",
    "expo-web-browser": "~12.3.2",
    "fbjs": "^3.0.5",
    "moment": "^2.29.4",
    "react": "18.2.0",
    "react-hook-form": "^7.47.0",
    "react-native": "0.72.7",
    "react-native-config": "^1.5.1",
    "react-native-date-picker": "^4.3.3",
    "react-native-document-picker": "^9.1.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.13.4",
    "react-native-image-picker": "^7.0.3",
    "react-native-keychain": "^8.1.3",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "^1.8.0",
    "react-native-modal": "^13.0.1",
    "react-native-permissions": "^3.10.1",
    "react-native-qrcode-scanner": "^1.5.5",
    "react-native-reanimated": "^3.5.4",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.27.0",
    "react-native-svg": "^13.14.0",
    "react-native-toast-message": "^2.1.7",
    "react-native-vector-icons": "^10.0.2",
    "react-native-web": "~0.19.13",
    "socket.io-client": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@expo/cli": "^0.10.16",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@react-native/typescript-config": "^0.73.1",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "~18.2.79",
    "@types/react-test-renderer": "^18.0.0",
    "@vitejs/plugin-react": "^4.1.0",
    "babel-jest": "^29.2.1",
    "babel-loader": "^9.1.3",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4",
    "url-loader": "^4.1.1",
    "vite": "^5.0.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "jest": {
    "preset": "react-native"
  }
}
