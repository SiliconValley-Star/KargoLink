# =================================================================
# CargoLink Production Environment Configuration
# =================================================================
# Copy this file to .env and configure the values for your environment

# =================================================================
# Application Settings
# =================================================================
NODE_ENV=production
APP_VERSION=1.0.0
API_BASE_URL=https://api.cargolink.com.tr
FRONTEND_URL=https://cargolink.com.tr
ADMIN_URL=https://admin.cargolink.com.tr

# =================================================================
# Server Configuration
# =================================================================
PORT=3001
BACKEND_PORT=3001
ADMIN_PORT=3002
HTTP_PORT=80
HTTPS_PORT=443

# =================================================================
# Database Configuration
# =================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/cargolink
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_PORT=5432
DB_HOST=postgres
DB_USER=cargolink
DB_PASSWORD=your_secure_postgres_password

# =================================================================
# Redis Configuration
# =================================================================
REDIS_URL=redis://:password@localhost:6379
REDIS_PASSWORD=your_secure_redis_password
REDIS_PORT=6379
REDIS_HOST=redis

# =================================================================
# JWT Configuration
# =================================================================
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =================================================================
# Security Configuration
# =================================================================
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production
CORS_ORIGIN=https://cargolink.com.tr,https://admin.cargolink.com.tr

# =================================================================
# AWS S3 Configuration
# =================================================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=cargolink-production-files

# =================================================================
# External APIs - Cargo Services
# =================================================================
YURTICI_ENABLED=true
YURTICI_API_KEY=your_yurtici_api_key
YURTICI_API_SECRET=your_yurtici_api_secret
YURTICI_API_URL=https://api.yurtici.com.tr/v2

ARAS_ENABLED=true
ARAS_API_KEY=your_aras_api_key
ARAS_API_SECRET=your_aras_api_secret
ARAS_API_URL=https://api.araskargo.com.tr/v1

MNG_ENABLED=true
MNG_API_KEY=your_mng_api_key
MNG_USERNAME=your_mng_username
MNG_PASSWORD=your_mng_password
MNG_API_URL=https://api.mngkargo.com.tr/v1

DHL_ENABLED=false
DHL_API_KEY=your_dhl_api_key
DHL_API_SECRET=your_dhl_api_secret
DHL_API_URL=https://api.dhl.com/parcel/tr/v1

UPS_ENABLED=false
UPS_API_KEY=your_ups_api_key
UPS_API_SECRET=your_ups_api_secret
UPS_API_URL=https://api.ups.com/track/v1

# =================================================================
# Payment Gateway Configuration
# =================================================================
IYZICO_ENABLED=true
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_WEBHOOK_SECRET=your_iyzico_webhook_secret

PAYTR_ENABLED=true
PAYTR_MERCHANT_ID=your_paytr_merchant_id
PAYTR_MERCHANT_KEY=your_paytr_merchant_key
PAYTR_MERCHANT_SALT=your_paytr_merchant_salt
PAYTR_BASE_URL=https://www.paytr.com
PAYTR_WEBHOOK_SECRET=your_paytr_webhook_secret

# =================================================================
# Email Configuration (SMTP)
# =================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@cargolink.com.tr

# =================================================================
# SMS Configuration
# =================================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# =================================================================
# External Services
# =================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
WEATHER_API_KEY=your_weather_api_key

# =================================================================
# Rate Limiting
# =================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# =================================================================
# Logging Configuration
# =================================================================
LOG_LEVEL=info

# =================================================================
# Feature Flags
# =================================================================
ENABLE_SWAGGER=false
ENABLE_SEEDING=false

# =================================================================
# Docker Configuration
# =================================================================
DOCKER_TARGET=production

# =================================================================
# Frontend Configuration (Admin Panel)
# =================================================================
VITE_API_URL=https://api.cargolink.com.tr
VITE_APP_NAME=CargoLink Admin
VITE_APP_VERSION=1.0.0

# =================================================================
# SSL Configuration (for production)
# =================================================================
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/private.key
SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem

# =================================================================
# Monitoring & Analytics (Optional)
# =================================================================
SENTRY_DSN=your_sentry_dsn_url
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX